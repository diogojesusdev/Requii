{
    "name": "requii",
    "version": "0.1.0",
    "license": "MIT",
    "type": "module",
    "author": "Diogo Jesus",
    "description": "Local-first API client built with Electron, React, Tailwind, Axios, and the host file system.",
    "main": "dist-electron/electron/main.cjs",
    "scripts": {
        "dev": "concurrently -k \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"vite\" \"wait-on tcp:5173 file:dist-electron/electron/main.cjs && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
        "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
        "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
        "build:electron": "tsc -p tsconfig.electron.json",
        "build": "npm run build:electron && npm run typecheck:app && vite build",
        "start": "npm run build:electron && electron .",
        "dist:win": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-windows.ps1 all",
        "dist:win:installer": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-windows.ps1 installer",
        "dist:win:portable": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-windows.ps1 portable",
        "dist:portable": "npm run dist:win:portable",
        "dist:mac": "npm run build && electron-builder --mac dmg pkg zip",
        "dist:mac:installer": "npm run build && electron-builder --mac dmg pkg",
        "dist:mac:portable": "npm run build && electron-builder --mac zip",
        "dist:linux": "npm run build && electron-builder --linux AppImage deb rpm tar.gz",
        "dist:linux:installer": "npm run build && electron-builder --linux deb rpm",
        "dist:linux:portable": "npm run build && electron-builder --linux AppImage tar.gz"
    },
    "build": {
        "appId": "com.requii.app",
        "productName": "Requii",
        "compression": "maximum",
        "electronLanguages": [
            "en-US"
        ],
        "directories": {
            "output": "release"
        },
        "afterPack": "./scripts/electron-builder-after-pack.cjs",
        "files": [
            "dist/**/*",
            "dist-electron/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "build/icon.ico",
                "to": "icon.ico"
            },
            {
                "from": "build/icon.png",
                "to": "icon.png"
            }
        ],
        "win": {
            "icon": "build/icon.ico",
            "signAndEditExecutable": false,
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "msi",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "mac": {
            "icon": "build/icon-macos.png",
            "category": "public.app-category.developer-tools",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "pkg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "zip",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
        },
        "linux": {
            "maintainer": "Diogo Jesus",
            "icon": "build/icon.png",
            "category": "Development",
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "deb",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "rpm",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "tar.gz",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
        },
        "nsis": {
            "artifactName": "${productName}-${version}-windows-${arch}-installer.${ext}",
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "perMachine": false,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "runAfterFinish": true,
            "shortcutName": "Requii",
            "installerIcon": "build/icon.ico",
            "uninstallerIcon": "build/icon.ico",
            "installerHeaderIcon": "build/icon.ico"
        },
        "portable": {
            "artifactName": "${productName}-${version}-windows-${arch}-portable.${ext}"
        },
        "msi": {
            "artifactName": "${productName}-${version}-windows-${arch}-installer.${ext}"
        },
        "pkg": {
            "installLocation": "/Applications"
        }
    },
    "dependencies": {
        "axios": "^1.8.4",
        "yaml": "^2.8.2"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^4.3.4",
        "@monaco-editor/react": "^4.7.0",
        "autoprefixer": "^10.4.21",
        "concurrently": "^9.1.2",
        "cross-env": "^7.0.3",
        "electron": "^35.0.1",
        "electron-builder": "^25.1.8",
        "rcedit": "^5.0.2",
        "monaco-editor": "^0.55.1",
        "postcss": "^8.5.3",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "tailwindcss": "^3.4.17",
        "textarea-caret-position": "^0.1.1",
        "typescript": "^5.9.3",
        "vite": "^6.2.2",
        "wait-on": "^8.0.3"
    }
}
